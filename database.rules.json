{
  "rules": {

    // ── Regra raiz: requer auth para tudo ────────────────────────────────
    // Cobre TODOS os paths automaticamente — sem risco de path esquecido
    ".read":  "auth != null",
    ".write": "auth != null",

    // ── Audit Log — append-only (sobrescreve a regra raiz) ───────────────
    // Usuário autenticado pode criar registros, mas NUNCA editar ou deletar
    "audit_log": {
      ".read": "auth != null",
      "$entry": {
        ".write": "auth != null && !data.exists()"
      }
    }

  }
}
