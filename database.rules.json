{
  "rules": {

    // ── Regra raiz: leitura requer auth ──────────────────────────────────────
    // Write na raiz restrito a contas @solucaoderua.app (admin)
    // Caminhos que técnicos escrevem têm regras próprias abaixo (auth anônima OK)
    ".read":  "auth != null",
    ".write": "auth != null && auth.token.email != null && auth.token.email.endsWith('@solucaoderua.app')",

    // ── Ordens de Serviço ────────────────────────────────────────────────────
    // Técnicos usam signInAnonymously — precisa de regra própria
    "os": {
      ".indexOn": ["userId", "data"],
      ".write": "auth != null"
    },

    // ── Dados dos usuários (técnicos) ────────────────────────────────────────
    // Técnico atualiza seus próprios dados: empresa, termoServicos, firstLogin
    "users": {
      ".write": "auth != null"
    },

    // ── Contratos de prestação de serviço ────────────────────────────────────
    "contratos": {
      ".write": "auth != null"
    },

    // ── Segurança: documentos, pendentes, inventários, EPI ──────────────────
    "seguranca": {
      ".write": "auth != null"
    },

    // ── Relatórios (OS importadas pelo fiscal) ───────────────────────────────
    "relatorios": {
      ".write": "auth != null"
    },

    // ── Descontos / parcelamentos (escolhas A/B dos técnicos) ────────────────
    "config": {
      "descontos": {
        ".indexOn": ["uid"],
        ".write": "auth != null"
      }
    },

    // ── Path legado de descontos ─────────────────────────────────────────────
    "descontos": {
      ".write": "auth != null"
    },

    // ── Mapeamento Firebase UID → App UID ────────────────────────────────────
    // Cada técnico só pode gravar seu próprio mapeamento (auth.uid === $fbUid)
    "authUidToAppUid": {
      ".read": "auth != null",
      "$fbUid": {
        ".write": "auth != null && auth.uid === $fbUid"
      }
    },

    // ── Audit Log — append-only ──────────────────────────────────────────────
    // Apenas contas SDR podem criar registros, NUNCA editar ou deletar
    "audit_log": {
      ".read": "auth != null",
      "$entry": {
        ".write": "auth != null && auth.token.email != null && auth.token.email.endsWith('@solucaoderua.app') && !data.exists()"
      }
    }

  }
}
