rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Relatórios de prestadores ──────────────────────────────────────────────
    // Upload: apenas admin autenticado (@solucaoderua.app ou qualquer auth)
    // Download: público — qualquer um com o link (token no URL) consegue baixar
    // Delete: qualquer usuário autenticado (inclui anônimo) — técnico apaga após assinar
    match /relatorios/{filename} {
      allow read:   if true;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── PDFs assinados (enviados pelo técnico pelo link do relatório) ──────────
    // Técnico usa auth anônima — qualquer auth permite upload e delete
    match /relatorios-assinados/{filename} {
      allow read:   if true;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

  }
}
